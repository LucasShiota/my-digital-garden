# ─── Obsidian Vault ───────────────────────────────────────────────────
# CRITICAL: Plugin API tokens — never commit
.obsidian/plugins/digitalgarden/data.json

# Obsidian workspace state (personal, regenerated per machine)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/graph.json
.obsidian/appearance.json

# Plugin binaries — compiled JS/CSS, not needed in git (100MB+)
# Obsidian downloads these automatically from manifests
.obsidian/plugins/*/main.js
.obsidian/plugins/*/styles.css
.obsidian/icons/

# ─── Local-only Drafts ──────────────────────────────────────────────
# Notes in _drafts/ are private and never pushed to git
src/site/notes/_drafts/
