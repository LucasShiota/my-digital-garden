{% set currentBanner = banner or noteData.banner or page.data.banner %}
{% if currentBanner %}
<div class="banner-container">
    {% set bannerFilename = currentBanner.split("/") | last %}
    <img src="{% if currentBanner.startsWith('http') %}{{ currentBanner }}{% else %}/img/banners/{{ bannerFilename }}{% endif %}" alt="Page Banner">
</div>
{% endif %}
