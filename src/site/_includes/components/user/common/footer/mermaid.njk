<script type="module">
  import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';

  (function() {
      document.addEventListener('DOMContentLoaded', async () => {
          // Initialize with current computed styles from our theme tokens
          mermaid.initialize({
              startOnLoad: false,
              theme: 'base',
              flowchart: {
                defaultRenderer: 'elk',
                useMaxWidth: true,
                htmlLabels: true,
                curve: 'basis'
              },
              themeVariables: {
                  primaryColor: getComputedStyle(document.body).getPropertyValue('--mermaid-node-bg').trim() || '#1e2233',
                  primaryBorderColor: getComputedStyle(document.body).getPropertyValue('--mermaid-node-border').trim() || '#7aa2f7',
                  primaryTextColor: getComputedStyle(document.body).getPropertyValue('--mermaid-text-color').trim() || '#c0caf5',
                  lineColor: getComputedStyle(document.body).getPropertyValue('--mermaid-line-color').trim() || '#9aa5ce',
                  secondaryColor: getComputedStyle(document.body).getPropertyValue('--mermaid-label-bg').trim() || '#16161e',
                  tertiaryColor: getComputedStyle(document.body).getPropertyValue('--background-secondary').trim() || '#16161e',
                  fontFamily: getComputedStyle(document.body).getPropertyValue('--mermaid-font').trim() || 'sans-serif',
                  fontSize: '14px'
              },
              securityLevel: 'loose'
          });

          const elements = document.querySelectorAll('.mermaid[data-mermaid-src]');
          for (const el of elements) {
              try {
                  const encoded = el.getAttribute('data-mermaid-src');
                  // Use a robust way to decode base64 including UTF-8
                  const code = decodeURIComponent(atob(encoded).split('').map(function(c) {
                      return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);
                  }).join(''));
                  
                  const id = 'mermaid-' + Math.random().toString(36).substr(2, 9);
                  const { svg } = await mermaid.render(id, code);
                  el.innerHTML = svg;
              } catch (e) {
                  console.error('Mermaid render error:', e);
                  el.innerHTML = '<pre class="error">Mermaid Syntax Error (Check Syntax)</pre>';
              }
          }
      });
  })();
</script>
