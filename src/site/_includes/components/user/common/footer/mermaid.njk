<script type="module">
  import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';

  (function() {
      // Configuration
      mermaid.initialize({
          startOnLoad: false,
          theme: 'forest', // Matches your garden's aesthetic
          securityLevel: 'loose',
          fontFamily: 'Atkinson Hyperlegible Next, sans-serif'
      });

      // Run on DOM ready
      document.addEventListener('DOMContentLoaded', async () => {
          // Explicitly run on .mermaid elements to avoid version 10 conflicts
          await mermaid.run({
              querySelector: '.mermaid'
          });
      });
  })();
</script>
