<div id="reading-ruler"></div>
<style>
  #reading-ruler {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0, 0, 0, 0.4); /* Dim the rest */
    pointer-events: none; /* Let clicks pass through */
    z-index: 9999;
    display: none; /* Hidden by default */
    backdrop-filter: blur(1.5px); /* Soften the background */
    
    /* Using a mask to create the "window" */
    --ruler-y: 50%;
    --ruler-height: 120px;
    
    clip-path: polygon(
      0% 0%, 
      100% 0%, 
      100% calc(var(--ruler-y) - (var(--ruler-height) / 2)), 
      0% calc(var(--ruler-y) - (var(--ruler-height) / 2)), 
      0% calc(var(--ruler-y) + (var(--ruler-height) / 2)), 
      100% calc(var(--ruler-y) + (var(--ruler-height) / 2)), 
      100% 100%, 
      0% 100%
    );
  }

  body.reading-mode-active #reading-ruler {
    display: block;
  }

  /* Optional: visual borders for the "slot" */
  #reading-ruler::before,
  #reading-ruler::after {
    content: '';
    position: absolute;
    left: 0;
    width: 100%;
    height: 1px;
    background: var(--accent-color, #4a9eff);
    opacity: 0.3;
  }

  #reading-ruler::before { top: calc(var(--ruler-y) - (var(--ruler-height) / 2)); }
  #reading-ruler::after { top: calc(var(--ruler-y) + (var(--ruler-height) / 2)); }
</style>

<script>
(function() {
  const ruler = document.getElementById('reading-ruler');
  let isActive = false;

  function setRulerState(active) {
    isActive = active;
    document.body.classList.toggle('reading-mode-active', isActive);
    
    // Update any toggle buttons in the UI
    const buttons = document.querySelectorAll('.a11y-toggle-btn[id="reading-ruler-btn"]');
    buttons.forEach(btn => {
        btn.classList.toggle('is-active', isActive);
        // Change icon to book-closed or similar if desired, 
        // but typically colored background is enough
    });
  }

  function toggleRuler() {
    setRulerState(!isActive);
  }

  // Handle Button Clicks (Delegated to handle dynamically added buttons)
  document.addEventListener('click', (e) => {
    const btn = e.target.closest('#reading-ruler-btn');
    if (btn) {
      e.preventDefault();
      toggleRuler();
    }
  });

  // Handle Keyboard Toggle (Alt + R)
  window.addEventListener('keydown', (e) => {
    if (e.altKey && (e.key === 'r' || e.key === 'R')) {
      e.preventDefault();
      toggleRuler();
    }
  });

  // Track Mouse Movement
  window.addEventListener('mousemove', (e) => {
    if (!isActive) return;
    ruler.style.setProperty('--ruler-y', e.clientY + 'px');
  });

  // Initial update for already rendered buttons
  setRulerState(false);
})();
</script>
