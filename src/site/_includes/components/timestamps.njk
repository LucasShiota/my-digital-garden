<script src=" https://fastly.jsdelivr.net/npm/luxon@3.2.1/build/global/luxon.min.js "></script>
<script defer>
  TIMESTAMP_FORMAT = "{{meta.timestampSettings.timestampFormat}}";
  document.querySelectorAll('.human-date').forEach(function (el) {
    const date = el.getAttribute('data-date');
    if (!date) return;
    const parsed_date = luxon.DateTime.fromISO(date);

    if (parsed_date.isValid) {
      // Use relative time (e.g. "3 days ago")
      el.innerHTML = parsed_date.toRelative();
      // Add title attribute to show the full exact date on hover
      el.setAttribute('title', parsed_date.toFormat(TIMESTAMP_FORMAT));
    }
  })
</script>