<script>
document.addEventListener("DOMContentLoaded", function() {
    function processTableMerges() {
        const tables = document.querySelectorAll(".markdown-rendered table");
        
        tables.forEach(table => {
            const rows = Array.from(table.rows);
            
            // 1. Horizontal Merging (<)
            rows.forEach(row => {
                for (let i = row.cells.length - 1; i > 0; i--) {
                    const cell = row.cells[i];
                    if (cell.innerText.trim() === "<") {
                        // Find the first non-merged cell to the left
                        let targetIndex = i - 1;
                        while (targetIndex >= 0 && row.cells[targetIndex].innerText.trim() === "<") {
                            targetIndex--;
                        }
                        
                        if (targetIndex >= 0) {
                            const targetCell = row.cells[targetIndex];
                            const currentSpan = parseInt(targetCell.getAttribute("colspan") || 1);
                            targetCell.setAttribute("colspan", currentSpan + 1);
                            cell.setAttribute('data-to-remove', 'true');
                            cell.style.display = 'none';
                        }
                    }
                }
            });

            // 2. Vertical Merging (^)
            for (let r = rows.length - 1; r > 0; r--) {
                const currentRow = rows[r];
                const aboveRow = rows[r - 1];
                
                for (let i = 0; i < currentRow.cells.length; i++) {
                    const cell = currentRow.cells[i];
                    if (cell.innerText.trim() === "^") {
                        // Attempt to find cell at same index in previous row
                        const targetCell = aboveRow.cells[i];
                        if (targetCell) {
                            const currentSpan = parseInt(targetCell.getAttribute("rowspan") || 1);
                            targetCell.setAttribute("rowspan", currentSpan + 1);
                            cell.setAttribute('data-to-remove', 'true');
                            cell.style.display = 'none';
                        }
                    }
                }
            }

            // Cleanup all marked cells
            table.querySelectorAll('[data-to-remove="true"]').forEach(el => el.remove());
        });
    }

    processTableMerges();
});
</script>
